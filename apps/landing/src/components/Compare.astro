---
import { stackChoices } from "../content/stack-choices.mdx";
import { competitors } from "../content/competitors.mdx";
import SectionMarker from "./SectionMarker.astro";
---
<section class="section compare" data-section-num="03" id="s03" aria-labelledby="cmp-headline">
  <SectionMarker num="03" label="Compare" right="What teams do today" />
  <h2 id="cmp-headline">What teams do today.</h2>
  <p class="lede compare-lede">
    Four common shapes. All of them ship the first app. None of them stay coherent
    across the next four.
  </p>

  <ol class="compare-grid">
    {stackChoices.map((c) => (
      <li class="compare-card">
        <span class="compare-k" aria-hidden="true">0{c.n}</span>
        <h3>{c.title}</h3>
        <p>{c.body}</p>
      </li>
    ))}
  </ol>

  <div class="compare-zoom" aria-labelledby="cmp-zoom-label">
    <div class="compare-zoom-head">
      <span class="compare-zoom-label" id="cmp-zoom-label">rntme / vs</span>
      <span class="compare-zoom-right">Named tools, same comparison</span>
    </div>
    <dl class="compare-rows">
      {competitors.map((c) => (
        <div class="compare-row">
          <dt>{c.name}</dt>
          <dd>{c.body}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .compare-lede {
    max-width: 58ch;
  }

  .compare-grid {
    list-style: none;
    padding: 0;
    margin: var(--space-5) 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-5) var(--space-4);
  }
  .compare-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border-strong);
  }
  .compare-k {
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    color: var(--color-text-subtle);
    font-variant-numeric: tabular-nums;
  }
  .compare-card h3 {
    margin: 0;
    max-width: 22ch;
    text-wrap: balance;
  }
  .compare-card p {
    margin: 0;
    color: var(--color-text-muted);
    max-width: 34ch;
  }

  .compare-zoom {
    margin-top: var(--space-6);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }
  .compare-zoom-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-text-subtle);
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }
  .compare-zoom-label {
    color: var(--color-text);
  }
  .compare-rows {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .compare-row {
    display: grid;
    grid-template-columns: minmax(200px, 22ch) 1fr;
    gap: var(--space-4);
    align-items: baseline;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .compare-row:last-child {
    border-bottom: none;
  }
  .compare-row dt {
    font-family: var(--font-display);
    font-weight: var(--fw-medium);
    font-size: var(--fs-body);
    color: var(--color-text);
    margin: 0;
  }
  .compare-row dd {
    margin: 0;
    color: var(--color-text-muted);
    max-width: 60ch;
  }

  @media (max-width: 720px) {
    .compare-row {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
