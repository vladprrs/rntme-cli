---
import SectionMarker from "./SectionMarker.astro";

const steps = [
  { k: "01", title: "Author a blueprint",   body: "One JSON file: domain, data, state transitions, HTTP/UI bindings, seed. Written by hand or by an agent." },
  { k: "02", title: "Validate in layers",   body: "Parse → structural → references → consistency. An agent cannot silently produce a broken service. Errors come with stable codes." },
  { k: "03", title: "Compile & migrate",    body: "The runtime produces the schema, the migration plan, and the event log your service needs. No manual DBA work." },
  { k: "04", title: "Boot the runtime",     body: "Same event log, same projection consumer, same HTTP surface, same UI surface — for every service. Zero service-specific code." },
  { k: "05", title: "Fork for service #2",  body: "Copy the blueprint. Change the domain. Ship. Service #5 reads like service #1." },
];

const asciiFlow = `  ┌──────────┐      ┌──────────┐      ┌──────────┐      ┌──────────┐      ┌──────────┐
  │  author  │ ───→ │ validate │ ───→ │ compile  │ ───→ │   boot   │ ───→ │   fork   │
  │blueprint │      │ in layers│      │& migrate │      │ runtime  │      │for svc#2 │
  └──────────┘      └──────────┘      └──────────┘      └──────────┘      └──────────┘
      <b>01</b>                <b>02</b>                <b>03</b>                <b>04</b>                <b>05</b>
                                                        <i>↑ event log appends at every arrow</i>`;

const flowNodes = [
  { k: "01", label: "author blueprint" },
  { k: "02", label: "validate in layers" },
  { k: "03", label: "compile & migrate" },
  { k: "04", label: "boot runtime" },
  { k: "05", label: "fork for svc#2" },
];
---
<section class="section howitworks" data-section-num="06" id="s06" aria-labelledby="hiw-headline">
  <SectionMarker num="06" label="How it works" right="Fig. 02 — pipeline" />
  <p class="label">How it works</p>
  <h2 id="hiw-headline">Make no mistakes.</h2>
  <pre class="ascii-flow ascii-flow-wide" aria-hidden="true" set:html={asciiFlow}></pre>
  <ol class="ascii-flow-stack" aria-hidden="true">
    {flowNodes.map((n, i) => (
      <>
        <li class="afs-node">
          <span class="afs-k">{n.k}</span>
          <span class="afs-box">{n.label}</span>
        </li>
        {i < flowNodes.length - 1 && <li class="afs-arrow" aria-hidden="true">↓</li>}
      </>
    ))}
    <li class="afs-note">↑ event log appends at every arrow</li>
  </ol>
  <ol class="steps">
    {steps.map((s) => (
      <li class="step">
        <div class="step-k">{s.k}</div>
        <div><h3>{s.title}</h3><p>{s.body}</p></div>
      </li>
    ))}
  </ol>
</section>
