---
import SectionMarker from "./SectionMarker.astro";

const steps = [
  { k: "01", title: "Author a blueprint",   body: "One JSON file: domain, data, state transitions, HTTP/UI bindings, seed. Written by hand or by an agent." },
  { k: "02", title: "Validate in layers",   body: "Parse → structural → references → consistency. An agent cannot silently produce a broken service. Errors come with stable codes." },
  { k: "03", title: "Compile & migrate",    body: "The runtime produces the schema, the migration plan, and the event log your service needs. No manual DBA work." },
  { k: "04", title: "Boot the runtime",     body: "Same event log, same projection consumer, same HTTP surface, same UI surface — for every service. Zero service-specific code." },
  { k: "05", title: "Fork for service #2",  body: "Copy the blueprint. Change the domain. Ship. Service #5 reads like service #1." },
];

const stepShort: Record<string, string> = {
  "01": "author blueprint",
  "02": "validate in layers",
  "03": "compile & migrate",
  "04": "boot runtime",
  "05": "fork for svc #2",
};

const asciiFlow = `  ┌──────────┐      ┌──────────┐      ┌──────────┐      ┌──────────┐      ┌──────────┐
  │  author  │ ───→ │ validate │ ───→ │ compile  │ ───→ │   boot   │ ───→ │   fork   │
  │blueprint │      │ in layers│      │& migrate │      │ runtime  │      │for svc#2 │
  └──────────┘      └──────────┘      └──────────┘      └──────────┘      └──────────┘
      <b data-k="01">01</b>                <b data-k="02">02</b>                <b data-k="03">03</b>                <b data-k="04">04</b>                <b data-k="05">05</b>
                                                        <i>↑ event log appends at every arrow</i>`;

const flowNodes = [
  { k: "01", label: "author blueprint" },
  { k: "02", label: "validate in layers" },
  { k: "03", label: "compile & migrate" },
  { k: "04", label: "boot runtime" },
  { k: "05", label: "fork for svc#2" },
];

const TICK_COUNT = 25;
const ticks = Array.from({ length: TICK_COUNT }, (_, i) => ({
  threshold: (i / TICK_COUNT).toFixed(4),
  arrow: i % 5 === 0,
}));

const stepNamesJson = JSON.stringify(stepShort);
---
<section
  class="section howitworks"
  data-section-num="06"
  id="s06"
  aria-labelledby="hiw-headline"
  data-current-step="01"
>
  <SectionMarker num="06" label="How it works" right="Fig. 02 — pipeline" />
  <p class="label">How it works</p>
  <h2 id="hiw-headline">Make no mistakes.</h2>
  <pre class="ascii-flow ascii-flow-wide" aria-hidden="true" set:html={asciiFlow}></pre>
  <ol class="ascii-flow-stack" aria-hidden="true">
    {flowNodes.map((n, i) => (
      <>
        <li class="afs-node">
          <span class="afs-k">{n.k}</span>
          <span class="afs-box">{n.label}</span>
        </li>
        {i < flowNodes.length - 1 && <li class="afs-arrow" aria-hidden="true">↓</li>}
      </>
    ))}
    <li class="afs-note">↑ event log appends at every arrow</li>
  </ol>

  <div class="hiw-trace" aria-hidden="true">
    <div class="hiw-trace-readout">
      <span class="hiw-trace-l">trace</span>
      <span class="hiw-trace-step">
        <span class="hiw-trace-k" data-hiw-cur-k>01</span><span class="hiw-trace-sep">/</span>05
      </span>
      <span class="hiw-trace-name" data-hiw-cur-name>{stepShort["01"]}</span>
    </div>
    <div class="hiw-rail">
      <ol class="hiw-rail-keys">
        {flowNodes.map((n) => (
          <li data-k={n.k}><span>{n.k}</span></li>
        ))}
      </ol>
      <div class="hiw-rail-line" role="presentation">
        {flowNodes.map((_, i) => (
          <span class="hiw-rail-node" style={`--n:${i}`}></span>
        ))}
      </div>
      <div class="hiw-rail-packet" role="presentation"></div>
    </div>
    <ol class="hiw-eventlog" aria-label="event log">
      {ticks.map((t) => (
        <li
          class={t.arrow ? "hiw-tick hiw-tick-arrow" : "hiw-tick"}
          style={`--t:${t.threshold}`}
        ></li>
      ))}
    </ol>
    <p class="hiw-eventlog-cap">
      <span>event log</span>
      <span class="hiw-eventlog-count" data-hiw-cur-count>0 / {TICK_COUNT} appended</span>
    </p>
  </div>

  <ol class="steps">
    {steps.map((s) => (
      <li class="step" data-step={s.k}>
        <div class="step-k">{s.k}</div>
        <div><h3>{s.title}</h3><p>{s.body}</p></div>
      </li>
    ))}
  </ol>
</section>

<script is:inline define:vars={{ STEP_NAMES: stepNamesJson, TICK_COUNT }}>
  (() => {
    const section = document.getElementById("s06");
    if (!section) return;
    const names = JSON.parse(STEP_NAMES);
    const total = TICK_COUNT;

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");
    const elKey = section.querySelector("[data-hiw-cur-k]");
    const elName = section.querySelector("[data-hiw-cur-name]");
    const elCount = section.querySelector("[data-hiw-cur-count]");

    const setStatic = () => {
      section.dataset.currentStep = "05";
      section.style.setProperty("--hiw-progress", "1");
      if (elKey) elKey.textContent = "05";
      if (elName) elName.textContent = names["05"];
      if (elCount) elCount.textContent = total + " / " + total + " appended";
    };

    if (reduce.matches) { setStatic(); return; }

    const cssDriven = (() => {
      try { return CSS.supports("animation-timeline", "view()"); }
      catch { return false; }
    })();

    let visible = false;
    let lastK = "";
    let lastFilled = -1;
    let scheduled = false;

    const update = () => {
      scheduled = false;
      let progress;
      if (cssDriven) {
        const raw = getComputedStyle(section).getPropertyValue("--hiw-progress");
        progress = parseFloat(raw);
        if (!Number.isFinite(progress)) progress = 0;
      } else {
        const rect = section.getBoundingClientRect();
        const vh = window.innerHeight || 800;
        const span = rect.height + vh;
        const traveled = vh - rect.top;
        progress = Math.max(0, Math.min(1, traveled / span));
        section.style.setProperty("--hiw-progress", progress.toFixed(4));
      }
      const idx = Math.min(4, Math.max(0, Math.floor(progress * 5)));
      const k = String(idx + 1).padStart(2, "0");
      if (k !== lastK) {
        lastK = k;
        section.dataset.currentStep = k;
        if (elKey) elKey.textContent = k;
        if (elName) elName.textContent = names[k];
      }
      const filled = Math.min(total, Math.max(0, Math.floor(progress * total + 0.0001)));
      if (filled !== lastFilled) {
        lastFilled = filled;
        if (elCount) elCount.textContent = filled + " / " + total + " appended";
      }
    };

    const loop = () => {
      if (!visible) return;
      update();
      requestAnimationFrame(loop);
    };

    const onScroll = () => {
      if (cssDriven || scheduled || !visible) return;
      scheduled = true;
      requestAnimationFrame(update);
    };

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        const wasVisible = visible;
        visible = e.isIntersecting;
        if (visible && !wasVisible) {
          if (cssDriven) loop();
          else update();
        }
      });
    }, { threshold: 0 });
    io.observe(section);

    if (!cssDriven) {
      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onScroll, { passive: true });
    }

    reduce.addEventListener("change", (e) => {
      if (e.matches) { io.disconnect(); setStatic(); }
    });

    update();
  })();
</script>
