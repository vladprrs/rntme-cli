---
import SectionMarker from "./SectionMarker.astro";

const steps = [
  { k: "01", title: "Describe the service",  body: "One JSON file: domain, data, state transitions, HTTP/UI bindings, seed. Written by hand or by an agent." },
  { k: "02", title: "Validate before boot",  body: "Parse вҶ’ structural вҶ’ references вҶ’ consistency. An agent cannot silently produce a broken service. Errors come with stable codes." },
  { k: "03", title: "Compile & migrate",     body: "The runtime produces the schema, the migration plan, and the event log your service needs. No manual DBA work." },
  { k: "04", title: "Boot a working service", body: "Same event log, same projection consumer, same HTTP surface, same UI surface вҖ” for every service. Zero service-specific code." },
  { k: "05", title: "Reuse for the next one", body: "Copy the blueprint. Change the domain. Ship. The next workflow app isn't a new snowflake backend." },
];

const asciiFlow = `  в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ      в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ      в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ      в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ      в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
  в”Ӯ describe в”Ӯ в”Җв”Җв”ҖвҶ’ в”Ӯ validate в”Ӯ в”Җв”Җв”ҖвҶ’ в”Ӯ compile  в”Ӯ в”Җв”Җв”ҖвҶ’ в”Ӯ   boot   в”Ӯ в”Җв”Җв”ҖвҶ’ в”Ӯ  reuse   в”Ӯ
  в”Ӯblueprint в”Ӯ      в”Ӯ in layersв”Ӯ      в”Ӯ& migrate в”Ӯ      в”Ӯ service  в”Ӯ      в”Ӯ for next в”Ӯ
  в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ      в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ      в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ      в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ      в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
      <b>01</b>                <b>02</b>                <b>03</b>                <b>04</b>                <b>05</b>
                                                        <i>вҶ‘ event log appends at every arrow</i>`;

const flowNodes = [
  { k: "01", label: "describe blueprint" },
  { k: "02", label: "validate in layers" },
  { k: "03", label: "compile & migrate" },
  { k: "04", label: "boot service" },
  { k: "05", label: "reuse for next" },
];
---
<section class="section howitworks" data-section-num="05" id="s05" aria-labelledby="hiw-headline">
  <SectionMarker num="05" label="How it works" right="Fig. 02 вҖ” pipeline" />
  <h2 id="hiw-headline">From blueprint to running service.</h2>
  <pre class="ascii-flow ascii-flow-wide" aria-hidden="true" set:html={asciiFlow}></pre>
  <ol class="ascii-flow-stack" aria-hidden="true">
    {flowNodes.map((n, i) => (
      <>
        <li class="afs-node">
          <span class="afs-k">{n.k}</span>
          <span class="afs-box">{n.label}</span>
        </li>
        {i < flowNodes.length - 1 && <li class="afs-arrow" aria-hidden="true">вҶ“</li>}
      </>
    ))}
    <li class="afs-note">вҶ‘ event log appends at every arrow</li>
  </ol>
  <ol class="steps">
    {steps.map((s) => (
      <li class="step">
        <div class="step-k">{s.k}</div>
        <div><h3>{s.title}</h3><p>{s.body}</p></div>
      </li>
    ))}
  </ol>
</section>
