---
import { loadEnv } from "../env";
const env = loadEnv();
const tallyUrl = `https://tally.so/r/${env.TALLY_FORM_ID}`;

const proofs = [
  { k: "01", label: "Validated blueprints" },
  { k: "02", label: "API + UI from one spec" },
  { k: "03", label: "No service-specific backend code" },
  { k: "04", label: "Built for workflow-heavy apps" },
];
---
<section class="section hero" data-section-num="01" id="s01" aria-labelledby="hero-headline">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="hero-inner">
    <div class="hero-eyebrow">rntme · early access · 2026</div>
    <h1 id="hero-headline" class="hero-h1">
      <span class="hero-h1-setup">Your AI can build an app.</span>
      <span class="hero-h1-payoff">rntme helps it build one you can keep alive.</span>
    </h1>
    <p class="lede hero-lede">
      Vibe-coded apps ship fast, then turn into brittle, insecure codebases that get harder
      to change with every prompt.
    </p>
    <p class="hero-pitch">
      rntme turns a validated service blueprint into a working API and UI on a standard
      runtime, so every new service starts from guardrails instead of chaos.
    </p>
    <div class="cta-row">
      <a class="btn btn-primary" href={tallyUrl}>Request early access →</a>
      <a class="btn btn-secondary" href="#s04">See the blueprint demo</a>
    </div>
    <ul class="proof-strip" aria-label="What rntme gives you">
      {proofs.map((p, i) => (
        <li class="proof-chip" style={`--i:${i}`}>
          <span class="proof-crosshair" aria-hidden="true"></span>
          <span class="proof-k" aria-hidden="true" data-target={p.k}>--</span>
          <span class="proof-label">{p.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .hero-h1 {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin: 0;
  }
  .hero-h1-setup {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 1.0rem + 1.4vw, 2.0rem);
    font-weight: var(--fw-medium);
    letter-spacing: -0.01em;
    line-height: var(--lh-heading);
    color: var(--color-text-muted);
  }
  .hero-h1-payoff {
    font-family: var(--font-display);
    font-size: var(--fs-display);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-display);
    line-height: var(--lh-tight);
    text-wrap: balance;
    max-width: 22ch;
    display: inline-block;
  }
  .hero-pitch {
    max-width: 62ch;
    color: var(--color-text-muted);
  }

  .proof-strip {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: var(--space-3) 0 0;
    border-top: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-4);
  }
  .proof-chip {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 0;
  }
  .proof-k {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-text-subtle);
    font-variant-numeric: tabular-nums;
  }
  .proof-chip:first-child .proof-k {
    color: var(--color-accent-text);
  }
  .proof-label {
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    line-height: 1.35;
    color: var(--color-text);
    font-weight: var(--fw-medium);
    text-wrap: balance;
  }

  /* -------- Registration-mark crosshair --------------------------------- */
  .proof-crosshair {
    position: absolute;
    top: calc(var(--space-3) * -1 - 6px);
    left: 0;
    width: 9px;
    height: 9px;
    color: var(--color-accent);
    opacity: 0;
    pointer-events: none;
  }
  .proof-crosshair::before,
  .proof-crosshair::after {
    content: "";
    position: absolute;
    background: currentColor;
  }
  .proof-crosshair::before {
    left: 50%;
    top: 0;
    width: 1px;
    height: 100%;
    transform: translateX(-50%);
  }
  .proof-crosshair::after {
    top: 50%;
    left: 0;
    height: 1px;
    width: 100%;
    transform: translateY(-50%);
  }

  @media (max-width: 720px) {
    .proof-strip {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-3);
    }
  }

  /* -------- Mount choreography (runs ONCE on .is-ready) -----------------
     Progressive enhancement: only the .js branch hides initial state. A
     no-JS render shows the final state immediately. */

  :global(html.js .hero-grid) { opacity: 0; }
  :global(html.js) .hero-h1-payoff { clip-path: inset(0 100% 0 0); }
  :global(html.js) .proof-chip { opacity: 0.35; }

  :global(html.js .hero.is-ready .hero-grid) {
    animation: hero-grid-fade 840ms var(--ease-out) forwards;
  }
  :global(html.js .hero.is-ready) .hero-h1-payoff {
    animation: hero-wipe 1260ms var(--ease-out) 450ms forwards;
  }
  :global(html.js .hero.is-ready) .proof-chip {
    animation: hero-chip-mark 1260ms var(--ease-out) forwards;
    animation-delay: calc(1200ms + var(--i) * 540ms);
  }
  :global(html.js .hero.is-ready) .proof-crosshair {
    animation: hero-cross-blink 1560ms var(--ease-out) forwards;
    animation-delay: calc(1200ms + var(--i) * 540ms);
  }

  @keyframes hero-grid-fade {
    from { opacity: 0; }
    to   { opacity: 0.55; }
  }
  @keyframes hero-wipe {
    from { clip-path: inset(0 100% 0 0); }
    to   { clip-path: inset(0 0 0 0); }
  }
  @keyframes hero-chip-mark {
    0%   { opacity: 0.35; transform: translateY(2px); }
    60%  { opacity: 1;   transform: translateY(0); }
    100% { opacity: 1;   transform: translateY(0); }
  }
  @keyframes hero-cross-blink {
    0%   { opacity: 0; transform: scale(0.6); }
    35%  { opacity: 1; transform: scale(1); }
    100% { opacity: 0.28; transform: scale(1); }
  }

  /* Reduced-motion: render all the final state instantly, skip animation. */
  @media (prefers-reduced-motion: reduce) {
    :global(html.js .hero-grid) { opacity: 0.55; }
    :global(html.js) .hero-h1-payoff { clip-path: none; }
    :global(html.js) .proof-chip { opacity: 1; }
    :global(html.js) .proof-crosshair { opacity: 0.28; }
    :global(html.js .hero.is-ready .hero-grid),
    :global(html.js .hero.is-ready) .hero-h1-payoff,
    :global(html.js .hero.is-ready) .proof-chip,
    :global(html.js .hero.is-ready) .proof-crosshair { animation: none; }
  }
</style>

<script is:inline>
  (() => {
    const hero = document.querySelector(".hero");
    if (!hero) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const ks = hero.querySelectorAll(".proof-k");

    // Instant state for reduced motion — targets rendered straight away.
    if (reduced) {
      ks.forEach((el) => {
        const t = el.getAttribute("data-target");
        if (t) el.textContent = t;
      });
      hero.classList.add("is-ready");
      return;
    }

    // Flip proof-k from "--" to its target, staggered with the crosshair
    // mark-in so the number and the crosshair settle together.
    const flipAt = (el, delay) => {
      const target = el.getAttribute("data-target") || "--";
      window.setTimeout(() => { el.textContent = target; }, delay);
    };

    // Kick the whole sequence next frame so CSS initial state is painted.
    requestAnimationFrame(() => {
      hero.classList.add("is-ready");
      ks.forEach((el, i) => flipAt(el, 1200 + i * 540 + 540));
    });
  })();
</script>
