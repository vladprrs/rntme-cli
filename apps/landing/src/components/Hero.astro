---
import { loadEnv } from "../env";
const env = loadEnv();
const tallyUrl = `https://tally.so/r/${env.TALLY_FORM_ID}`;

const proofs = [
  { k: "01", label: "Validated blueprints" },
  { k: "02", label: "API + UI from one spec" },
  { k: "03", label: "No service-specific backend code" },
  { k: "04", label: "Built for workflow-heavy apps" },
];
---
<section class="section hero" data-section-num="01" id="s01" aria-labelledby="hero-headline">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="hero-inner">
    <div class="hero-eyebrow">rntme · pilot program · 2026</div>
    <h1 id="hero-headline" class="hero-h1">
      <span class="hero-h1-setup">Your AI can build an app.</span>
      <span class="hero-h1-payoff">rntme helps it build one you can keep alive.</span>
    </h1>
    <p class="lede hero-lede">
      Vibe-coded apps ship fast, then turn into brittle, insecure codebases that get harder
      to change with every prompt.
    </p>
    <p class="hero-pitch">
      rntme turns a validated service blueprint into a working API and UI on a standard
      runtime, so every new service starts from guardrails instead of chaos.
    </p>
    <div class="cta-row">
      <a class="btn btn-primary" href={tallyUrl}>Apply for the pilot →</a>
      <a class="btn btn-secondary" href="#s04">See the blueprint demo</a>
    </div>
    <ul class="proof-strip" aria-label="What rntme gives you">
      {proofs.map((p) => (
        <li class="proof-chip">
          <span class="proof-k" aria-hidden="true">{p.k}</span>
          <span class="proof-label">{p.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .hero-h1 {
    display: flex;
    flex-direction: column;
    gap: clamp(6px, 0.4vw + 4px, 12px);
    margin: 0;
  }
  .hero-h1-setup {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 1.0rem + 1.4vw, 2.0rem);
    font-weight: var(--fw-medium);
    letter-spacing: -0.01em;
    line-height: var(--lh-heading);
    color: var(--color-text-muted);
  }
  .hero-h1-payoff {
    font-family: var(--font-display);
    font-size: var(--fs-display);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-display);
    line-height: var(--lh-tight);
    text-wrap: balance;
    max-width: 22ch;
  }
  .hero-pitch {
    max-width: 62ch;
    color: var(--color-text-muted);
  }

  .proof-strip {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: var(--space-3) 0 0;
    border-top: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-4);
  }
  .proof-chip {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 0;
  }
  .proof-k {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-text-subtle);
    font-variant-numeric: tabular-nums;
  }
  .proof-chip:first-child .proof-k {
    color: var(--color-accent-text);
  }
  .proof-label {
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    line-height: 1.35;
    color: var(--color-text);
    font-weight: var(--fw-medium);
    text-wrap: balance;
  }

  @media (max-width: 720px) {
    .proof-strip {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-3);
    }
  }
</style>
