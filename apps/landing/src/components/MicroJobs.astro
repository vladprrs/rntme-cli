---
import { coreJob, microJobs } from "../content/micro-jobs.mdx";
import SectionMarker from "./SectionMarker.astro";
---
<section class="section microjobs" data-section-num="02" id="s02" aria-labelledby="mj-headline">
  <SectionMarker num="02" label="Core job" right="Three things, end-to-end" />
  <p class="label">Core job</p>
  <h2 id="mj-headline">{coreJob}</h2>
  <div class="microjobs-grid">
    {microJobs.map((m) => (
      <article class="microjob-card">
        <span class="label mj-k">0{m.n}</span>
        <h3>{m.title}</h3>
        <p class="mj-action">{m.action}</p>
        <p class="mj-value"><strong>→</strong> {m.value}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .microjobs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-4);
    margin-top: var(--space-5);
  }
  .microjob-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }
  .mj-k { margin-bottom: var(--space-2); }
  .microjob-card h3 { margin: var(--space-2) 0 var(--space-2); }
  .mj-action { color: var(--color-text-muted); margin-bottom: var(--space-3); }
  .mj-value { color: var(--color-accent-text); margin-bottom: 0; }
</style>
