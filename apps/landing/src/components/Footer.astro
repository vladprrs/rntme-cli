---
import { loadEnv } from "../env";
const env = loadEnv();
const year = new Date().getFullYear();
---
<footer class="section footer" data-section-num="10" id="s10" aria-label="Site footer">
  <div class="footer-top">
    <a class="footer-logo" href="/" aria-label="rntme home">rntme</a>
    <nav class="footer-nav" aria-label="Footer">
      <a href={env.GITHUB_URL} rel="noopener">GitHub</a>
      <a href={env.DOCS_URL}>Docs</a>
      <a href={env.PLATFORM_URL}>Platform login</a>
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
    </nav>
  </div>
  <hr/>
  <div class="footer-bottom">
    <div>© {year} rntme</div>
    <div>Make no mistakes.</div>
  </div>
</footer>
