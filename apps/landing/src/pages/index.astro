---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Problem from "../components/Problem.astro";
import Compare from "../components/Compare.astro";
import AhaSection from "../components/AhaSection.astro";
import HowItWorks from "../components/HowItWorks.astro";
import BestFit from "../components/BestFit.astro";
import AntiFit from "../components/AntiFit.astro";
import PilotForm from "../components/PilotForm.astro";
import Objections from "../components/Objections.astro";
import Footer from "../components/Footer.astro";
---
<BaseLayout
  title="rntme — the safe runtime for AI-generated workflow apps"
  description="Vibe-coded apps ship fast, then turn into brittle codebases. rntme turns a validated service blueprint into a working API and UI on a standard runtime, so every new service starts from guardrails instead of chaos."
>
  <main id="main">
    <Hero />
    <Problem />
    <Compare />
    <AhaSection />
    <HowItWorks />
    <BestFit />
    <AntiFit />
    <PilotForm />
    <Objections />
  </main>
  <Footer />
</BaseLayout>
