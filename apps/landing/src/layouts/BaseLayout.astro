---
import "../styles/global.css";
import { loadEnv } from "../env";
import StatusBar from "../components/StatusBar.astro";
import { SideRail } from "../components/SideRail";

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical = Astro.url.href } = Astro.props;
const env = loadEnv();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {/* Webfonts — Supreme (display) + Switzer (body) from Fontshare.
        Preconnect first to warm the TLS handshake, then fetch with display=swap
        so body text renders immediately in the fallback stack while the
        custom faces download. */}
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=supreme@500,600,700&f[]=switzer@400,500,600,700&display=swap"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    {env.PLAUSIBLE_DOMAIN && (
      <script
        is:inline
        defer
        data-domain={env.PLAUSIBLE_DOMAIN}
        src="https://plausible.io/js/script.js"
      />
    )}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to main content</a>
    <StatusBar />
    <SideRail client:idle />
    <slot />
  </body>
</html>
