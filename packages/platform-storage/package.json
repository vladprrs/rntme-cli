{
  "name": "@rntme-cli/platform-storage",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "Postgres (Drizzle + RLS) and rustfs (S3) adapters for platform-core.",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.check.json",
    "lint": "eslint --no-error-on-unmatched-pattern \"src/**/*.ts\" \"test/**/*.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@rntme-cli/platform-core": "workspace:*",
    "@aws-sdk/client-s3": "^3.650.0",
    "@aws-sdk/s3-request-presigner": "^3.650.0",
    "drizzle-orm": "^0.36.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@testcontainers/postgresql": "^10.13.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.10.0",
    "prettier": "^3.3.3",
    "testcontainers": "^10.13.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  }
}
